generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Branch — represents a physical location / branch of Akshaya Patra
model Branch {
  id          String       @id @default(cuid())
  name        String       @unique
  location    String
  branchType  BranchType   @default(SMALL)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]

  branchEvalConfigs  BranchEvalConfig[]
  hodAssignments     HodAssignment[]
  branchShortlist1   BranchShortlistStage1[]
  branchShortlist2   BranchShortlistStage2[]
  branchShortlist3   BranchShortlistStage3[]
  branchShortlist4   BranchShortlistStage4[]
  branchBestEmployees BranchBestEmployee[]

  @@map("branches")
}

/// Department — organizational unit within a branch
model Department {
  id              String            @id @default(cuid())
  name            String
  branchId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  branchManagerId String?
  supervisorId    String?
  bestEmployees   BestEmployee[]
  departmentRoles DepartmentRoleMapping[]
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  shortlistStage1 ShortlistStage1[]
  shortlistStage2 ShortlistStage2[]
  shortlistStage3 ShortlistStage3[]
  users           User[]
  hodAssignments  HodAssignment[]

  @@unique([name, branchId])
  @@index([branchId])
  @@map("departments")
}

/// User — all employees, supervisors, managers, and admins
model User {
  id                    String                     @id @default(cuid())
  empCode               String?                    @unique
  name                  String
  password              String
  role                  Role                       @default(EMPLOYEE)
  departmentId          String?
  collarType            CollarType?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  designation           String?
  mobile                String?
  auditLogs             AuditLog[]
  bestEmployees         BestEmployee[]
  bmReceived            BranchManagerEvaluation[]  @relation("EmployeeBMEval")
  bmEvaluations         BranchManagerEvaluation[]  @relation("BMGiven")
  cmEvaluations         ClusterManagerEvaluation[] @relation("CMGiven")
  cmReceived            ClusterManagerEvaluation[] @relation("EmployeeCMEval")
  departmentRoles       DepartmentRoleMapping[]
  notifications         Notification[]
  selfAssessments       SelfAssessment[]
  shortlistStage1       ShortlistStage1[]
  shortlistStage2       ShortlistStage2[]
  shortlistStage3       ShortlistStage3[]
  supervisorReceived    SupervisorEvaluation[]     @relation("EmployeeSupEval")
  supervisorEvaluations SupervisorEvaluation[]     @relation("SupervisorGiven")
  assignedQuestions     EmployeeQuarterQuestions[]
  department            Department?                @relation(fields: [departmentId], references: [id])

  // New relations for redesign
  hodEvaluationsGiven    HodEvaluation[]           @relation("HODGiven")
  hodEvaluationsReceived HodEvaluation[]           @relation("EmployeeHODEval")
  hrEvaluationsGiven     HrEvaluation[]            @relation("HRGiven")
  hrEvaluationsReceived  HrEvaluation[]            @relation("EmployeeHREval")
  hodAssignments         HodAssignment[]
  branchShortlist1       BranchShortlistStage1[]
  branchShortlist2       BranchShortlistStage2[]
  branchShortlist3       BranchShortlistStage3[]
  branchShortlist4       BranchShortlistStage4[]
  branchBestEmployees    BranchBestEmployee[]

  @@index([departmentId])
  @@index([role])
  @@index([departmentId, role])
  @@map("users")
}

/// Quarter — evaluation period (e.g. Q1-2025)
model Quarter {
  id                    String                     @id @default(cuid())
  name                  String                     @unique
  status                QuarterStatus              @default(ACTIVE)
  startDate             DateTime
  endDate               DateTime
  questionCount         Int                        @default(15)
  bmQuestionCount       Int                        @default(4)
  hodQuestionCount      Int                        @default(4)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  bestEmployees         BestEmployee[]
  bmEvaluations         BranchManagerEvaluation[]
  cmEvaluations         ClusterManagerEvaluation[]
  quarterQuestions      QuarterQuestion[]
  employeeQuestions     EmployeeQuarterQuestions[]
  selfAssessments       SelfAssessment[]
  shortlistStage1       ShortlistStage1[]
  shortlistStage2       ShortlistStage2[]
  shortlistStage3       ShortlistStage3[]
  supervisorEvaluations SupervisorEvaluation[]

  // New relations for redesign
  hodEvaluations        HodEvaluation[]
  hrEvaluations         HrEvaluation[]
  branchEvalConfigs     BranchEvalConfig[]
  hodAssignments        HodAssignment[]
  branchShortlist1      BranchShortlistStage1[]
  branchShortlist2      BranchShortlistStage2[]
  branchShortlist3      BranchShortlistStage3[]
  branchShortlist4      BranchShortlistStage4[]
  branchBestEmployees   BranchBestEmployee[]

  @@index([status])
  @@map("quarters")
}

/// Question — individual evaluation question
model Question {
  id               String            @id @default(cuid())
  text             String
  category         QuestionCategory
  level            EvaluationLevel
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  textHindi        String            @default("")
  quarterQuestions        QuarterQuestion[]
  employeeAssignments     EmployeeQuarterQuestions[]

  @@index([category])
  @@index([level])
  @@index([level, isActive])
  @@map("questions")
}

/// QuarterQuestion — links a Question to a Quarter (locked set for that quarter)
model QuarterQuestion {
  id         String   @id @default(cuid())
  quarterId  String
  questionId String
  createdAt  DateTime @default(now())
  quarter    Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([quarterId, questionId])
  @@index([quarterId])
  @@index([questionId])
  @@map("quarter_questions")
}

/// SelfAssessment — employee's self-evaluation
model SelfAssessment {
  id              String   @id @default(cuid())
  userId          String
  quarterId       String
  answers         Json
  submittedAt     DateTime @default(now())
  maxScore              Float
  normalizedScore       Float
  rawScore              Float
  completionTimeSeconds Int      @default(0)
  quarter               Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@index([quarterId])
  @@index([userId, quarterId])
  @@map("self_assessments")
}

/// @deprecated — Supervisor stage removed in redesign. Kept for historical data.
model SupervisorEvaluation {
  id                     String   @id @default(cuid())
  supervisorId           String
  employeeId             String
  quarterId              String
  answers                Json
  submittedAt            DateTime @default(now())
  selfContribution       Float
  stage2CombinedScore    Float
  supervisorContribution Float
  supervisorNormalized   Float
  supervisorRawScore     Float
  employee               User     @relation("EmployeeSupEval", fields: [employeeId], references: [id], onDelete: Cascade)
  quarter                Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  supervisor             User     @relation("SupervisorGiven", fields: [supervisorId], references: [id], onDelete: Cascade)

  @@unique([supervisorId, employeeId, quarterId])
  @@index([employeeId])
  @@index([quarterId])
  @@index([employeeId, quarterId])
  @@map("supervisor_evaluations")
}

/// BranchManagerEvaluation — branch manager evaluates an employee
model BranchManagerEvaluation {
  id                     String   @id @default(cuid())
  managerId              String
  employeeId             String
  quarterId              String
  answers                Json
  submittedAt            DateTime @default(now())
  bmContribution         Float
  bmNormalized           Float
  bmRawScore             Float
  selfContribution       Float
  stage3CombinedScore    Float
  supervisorContribution Float
  employee               User     @relation("EmployeeBMEval", fields: [employeeId], references: [id], onDelete: Cascade)
  manager                User     @relation("BMGiven", fields: [managerId], references: [id], onDelete: Cascade)
  quarter                Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@unique([managerId, employeeId, quarterId])
  @@index([employeeId])
  @@index([quarterId])
  @@index([employeeId, quarterId])
  @@map("branch_manager_evaluations")
}

/// ClusterManagerEvaluation — cluster manager gives final evaluation
model ClusterManagerEvaluation {
  id                     String   @id @default(cuid())
  clusterId              String
  employeeId             String
  quarterId              String
  answers                Json
  finalScore             Float
  submittedAt            DateTime @default(now())
  bmContribution         Float
  cmContribution         Float
  cmNormalized           Float
  cmRawScore             Float
  selfContribution       Float
  supervisorContribution Float
  cluster                User     @relation("CMGiven", fields: [clusterId], references: [id], onDelete: Cascade)
  employee               User     @relation("EmployeeCMEval", fields: [employeeId], references: [id], onDelete: Cascade)
  quarter                Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@unique([clusterId, employeeId, quarterId])
  @@index([employeeId])
  @@index([quarterId])
  @@index([employeeId, quarterId])
  @@map("cluster_manager_evaluations")
}

/// AuditLog — tracks all significant actions in the system
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// @deprecated — Department-level shortlist. Kept for historical data.
model ShortlistStage1 {
  id           String     @id @default(cuid())
  userId       String
  quarterId    String
  departmentId String
  selfScore    Float
  rank         Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  quarter      Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@unique([departmentId, quarterId, rank])
  @@index([quarterId])
  @@index([departmentId])
  @@map("shortlist_stage1")
}

/// @deprecated — Department-level shortlist. Kept for historical data.
model ShortlistStage2 {
  id              String     @id @default(cuid())
  userId          String
  quarterId       String
  departmentId    String
  selfScore       Float
  supervisorScore Float
  combinedScore   Float
  rank            Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  quarter         Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@unique([departmentId, quarterId, rank])
  @@index([quarterId])
  @@index([departmentId])
  @@map("shortlist_stage2")
}

/// @deprecated — Department-level shortlist. Kept for historical data.
model ShortlistStage3 {
  id              String     @id @default(cuid())
  userId          String
  quarterId       String
  departmentId    String
  selfScore       Float
  supervisorScore Float
  bmScore         Float
  combinedScore   Float
  rank            Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  quarter         Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@unique([departmentId, quarterId, rank])
  @@index([quarterId])
  @@index([departmentId])
  @@map("shortlist_stage3")
}

/// @deprecated — Department-level best employee. Kept for historical data.
model BestEmployee {
  id              String     @id @default(cuid())
  userId          String
  quarterId       String
  departmentId    String
  selfScore       Float
  supervisorScore Float
  bmScore         Float
  cmScore         Float
  finalScore      Float
  createdAt       DateTime   @default(now())
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  quarter         Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quarterId, departmentId])
  @@index([userId])
  @@map("best_employees")
}

/// Notification — in-app notifications for users
model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// BlacklistedToken — invalidated JWTs (logout / forced invalidation)
model BlacklistedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("blacklisted_tokens")
}

/// DepartmentRoleMapping — maps evaluators to departments
model DepartmentRoleMapping {
  id           String     @id @default(cuid())
  userId       String
  departmentId String
  role         Role
  assignedAt   DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId, role])
  @@index([departmentId])
  @@index([userId])
  @@map("department_role_mappings")
}

/// EmployeeQuarterQuestions — per-employee randomized question assignment
model EmployeeQuarterQuestions {
  id         String   @id @default(cuid())
  employeeId String
  quarterId  String
  questionId String
  orderIndex Int
  assignedAt DateTime @default(now())
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  quarter    Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([employeeId, quarterId, questionId])
  @@index([employeeId, quarterId])
  @@map("employee_quarter_questions")
}

/// ArchivedEmployee — soft-deleted employees with reason for leaving
model ArchivedEmployee {
  id             String   @id @default(cuid())
  empCode        String?
  name           String
  mobile         String?
  designation    String?
  department     String
  joiningDate    DateTime?
  removalDate    DateTime @default(now())
  reasonLeaving  String
  archivedBy     String
  originalUserId String?
  createdAt      DateTime @default(now())

  @@index([department])
  @@index([removalDate])
  @@map("archived_employees")
}

// ═══════════════════════════════════════════════════════════════
//  NEW MODELS — Branch-Level Evaluation Redesign
// ═══════════════════════════════════════════════════════════════

/// BranchEvalConfig — per-branch per-quarter evaluation settings
model BranchEvalConfig {
  id              String   @id @default(cuid())
  branchId        String
  quarterId       String
  stage1CutoffPct Float    @default(0.5)   // top 50% = 0.5
  stage2Limit     Int      @default(10)    // small: 10; big WC: 3; big BC: 10
  stage3Limit     Int      @default(5)     // small: 5; big WC: 2; big BC: 5
  stage4Limit     Int      @default(3)     // small: 3; big WC: 1; big BC: 3
  createdAt       DateTime @default(now())
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quarter         Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@unique([branchId, quarterId])
  @@map("branch_eval_configs")
}

/// HodAssignment — BM assigns HOD to department for a quarter (big branches)
model HodAssignment {
  id           String     @id @default(cuid())
  hodUserId    String
  branchId     String
  departmentId String
  quarterId    String
  assignedBy   String
  assignedAt   DateTime   @default(now())
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  hod          User       @relation(fields: [hodUserId], references: [id], onDelete: Cascade)
  quarter      Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@unique([hodUserId, departmentId, quarterId])
  @@index([branchId, quarterId])
  @@index([departmentId, quarterId])
  @@map("hod_assignments")
}

/// HodEvaluation — HOD evaluates blue collar employees (big branch Stage 2)
model HodEvaluation {
  id                  String   @id @default(cuid())
  hodId               String
  employeeId          String
  quarterId           String
  answers             Json
  submittedAt         DateTime @default(now())
  hodRawScore         Float
  hodNormalized       Float
  selfContribution    Float
  hodContribution     Float
  stage2CombinedScore Float
  hod                 User     @relation("HODGiven", fields: [hodId], references: [id], onDelete: Cascade)
  employee            User     @relation("EmployeeHODEval", fields: [employeeId], references: [id], onDelete: Cascade)
  quarter             Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@unique([hodId, employeeId, quarterId])
  @@index([employeeId, quarterId])
  @@map("hod_evaluations")
}

/// HrEvaluation — HR evaluates Stage 4 candidates with PDF uploads
model HrEvaluation {
  id                  String   @id @default(cuid())
  hrUserId            String
  employeeId          String
  quarterId           String
  attendancePdfUrl    String?
  punctualityPdfUrl   String?
  attendancePdfSize   Int?
  punctualityPdfSize  Int?
  notes               String?
  hrScore             Float    @default(0)
  submittedAt         DateTime @default(now())
  selfContribution    Float    @default(0)
  evaluatorContribution Float  @default(0)
  cmContribution      Float    @default(0)
  hrContribution      Float    @default(0)
  stage4CombinedScore Float    @default(0)
  hr                  User     @relation("HRGiven", fields: [hrUserId], references: [id], onDelete: Cascade)
  employee            User     @relation("EmployeeHREval", fields: [employeeId], references: [id], onDelete: Cascade)
  quarter             Quarter  @relation(fields: [quarterId], references: [id], onDelete: Cascade)

  @@unique([hrUserId, employeeId, quarterId])
  @@index([employeeId, quarterId])
  @@map("hr_evaluations")
}

/// BranchShortlistStage1 — Top 50% of branch employees after self-assessment
model BranchShortlistStage1 {
  id           String      @id @default(cuid())
  userId       String
  quarterId    String
  branchId     String
  collarType   CollarType?
  selfScore    Float
  rank         Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  branch       Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quarter      Quarter     @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@unique([branchId, quarterId, rank])
  @@index([branchId, quarterId])
  @@map("branch_shortlist_stage1")
}

/// BranchShortlistStage2 — After BM/HOD evaluation
model BranchShortlistStage2 {
  id              String     @id @default(cuid())
  userId          String
  quarterId       String
  branchId        String
  collarType      CollarType
  selfScore       Float
  evaluatorScore  Float
  combinedScore   Float
  rank            Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  branch          Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quarter         Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@index([branchId, quarterId, collarType])
  @@map("branch_shortlist_stage2")
}

/// BranchShortlistStage3 — After CM evaluation
model BranchShortlistStage3 {
  id              String     @id @default(cuid())
  userId          String
  quarterId       String
  branchId        String
  collarType      CollarType
  selfScore       Float
  evaluatorScore  Float
  cmScore         Float
  combinedScore   Float
  rank            Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  branch          Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quarter         Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@index([branchId, quarterId, collarType])
  @@map("branch_shortlist_stage3")
}

/// BranchShortlistStage4 — After HR evaluation (final shortlist before committee)
model BranchShortlistStage4 {
  id                  String     @id @default(cuid())
  userId              String
  quarterId           String
  branchId            String
  collarType          CollarType
  selfScore           Float
  evaluatorScore      Float
  cmScore             Float
  hrScore             Float
  attendancePdfUrl    String?
  punctualityPdfUrl   String?
  combinedScore       Float
  rank                Int
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  branch              Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quarter             Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@index([branchId, quarterId, collarType])
  @@map("branch_shortlist_stage4")
}

/// BranchBestEmployee — Final best employees per branch per collar type
model BranchBestEmployee {
  id              String     @id @default(cuid())
  userId          String
  quarterId       String
  branchId        String
  collarType      CollarType
  selfScore       Float
  evaluatorScore  Float
  cmScore         Float
  hrScore         Float
  finalScore      Float
  attendancePdfUrl  String?
  punctualityPdfUrl String?
  createdAt       DateTime   @default(now())
  branch          Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quarter         Quarter    @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, quarterId])
  @@index([branchId, quarterId, collarType])
  @@index([userId])
  @@map("branch_best_employees")
}

// ═══════════════════════════════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  EMPLOYEE
  SUPERVISOR
  HOD
  BRANCH_MANAGER
  CLUSTER_MANAGER
  HR
  COMMITTEE
  ADMIN
}

enum BranchType {
  SMALL
  BIG
}

enum CollarType {
  WHITE_COLLAR
  BLUE_COLLAR
}

enum QuarterStatus {
  ACTIVE
  CLOSED
}

enum QuestionCategory {
  ATTENDANCE
  DISCIPLINE
  PRODUCTIVITY
  TEAMWORK
  INITIATIVE
  COMMUNICATION
  INTEGRITY
}

enum EvaluationLevel {
  SELF
  SUPERVISOR
  HOD
  BRANCH_MANAGER
  CLUSTER_MANAGER
  HR
}
