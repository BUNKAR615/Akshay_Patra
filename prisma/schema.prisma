enum Role {
  EMPLOYEE
  SUPERVISOR
  HOD
  BRANCH_MANAGER
  CLUSTER_MANAGER
  HR
  COMMITTEE
  ADMIN
}

enum BranchType {
  SMALL
  BIG
}

enum CollarType {
  WHITE_COLLAR
  BLUE_COLLAR
}

enum QuarterStatus {
  ACTIVE
  CLOSED
}

enum QuestionCategory {
  ATTENDANCE
  DISCIPLINE
  PRODUCTIVITY
  TEAMWORK
  INITIATIVE
  COMMUNICATION
  INTEGRITY
}

enum EvaluationLevel {
  SELF
  SUPERVISOR
  HOD
  BRANCH_MANAGER
  CLUSTER_MANAGER
  HR
}

// ═══════════════════════════════════════════════════════════════
//  NEW MODELS — Online Exam Module (independent platform module)
//
//  Self-contained: internal relations (Exam→Question→Choice,
//  Exam→Invite, Exam→Response→Answer) are real with cascade deletes,
//  but references to existing entities (User / Branch / Department)
//  are stored as SCALAR ids only — no relations / back-relations — so
//  the heavily-related User/Branch/Department models are left untouched.
// ═══════════════════════════════════════════════════════════════

/// Exam — a single online assessment (Google-Forms style).
model Exam {
  id                String         @id @default(cuid())
  title             String
  description       String?
  status            ExamStatus     @default(DRAFT)
  timeLimitMin      Int? // null = untimed
  passMark          Int            @default(70) // percentage
  dueDate           DateTime?
  shuffle           Boolean        @default(true)
  showResults       Boolean        @default(false)
  requireCompletion Boolean        @default(true)
  // How the exam audience is composed (Phase A). CUSTOM = hand-picked internal
  // employees; INTERNAL = filter-defined internal set; INTERNAL_EXTERNAL / OPEN
  // additionally allow external/open registrants (Phase B).
  participationMode ExamParticipationMode @default(CUSTOM)
  // Phase B — external registration & access control.
  externalEmailRequired   Boolean          @default(true)
  externalMobileRequired  Boolean          @default(true)
  externalEmpCodeRequired Boolean          @default(true)
  externalApprovalMode    ExamApprovalMode @default(MANUAL)
  allowReattempts         Boolean          @default(false)
  // When true the exam is hidden from every employee's "My Exams" list — used
  // to retract a wrongly-created exam or one whose results are already out,
  // without deleting its responses. Reversible.
  hiddenFromEmployees     Boolean          @default(false)
  createdById       String // scalar ref → users.id (no relation)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  questions           ExamQuestion[]
  audience            ExamAudience?
  invites             ExamInvite[]
  responses           ExamResponse[]
  externalRegistrants ExternalRegistrant[]

  @@index([status])
  @@index([createdById])
  @@map("exams")
}

/// ExternalRegistrant — an Akshaya Patra employee outside the live directory
/// (e.g. non-Rajasthan branches) who registers to take an exam. Phase B.
model ExternalRegistrant {
  id           String           @id @default(cuid())
  examId       String
  name         String
  empCode      String
  email        String?
  mobile       String?
  department   String?
  branch       String?
  designation  String?
  status       RegistrantStatus @default(PENDING)
  // Issued when the registrant is approved — lets them open the exam via a
  // tokenized link without a full user account (B2).
  accessToken  String?          @unique
  reviewedById String? // scalar ref → users.id
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  exam         Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, empCode]) // one registration per employee code per exam
  @@index([examId, status])
  @@map("external_registrants")
}

/// ExamQuestion — one question within an exam.
model ExamQuestion {
  id       String           @id @default(cuid())
  examId   String
  order    Int
  type     ExamQuestionType
  text     String
  hint     String?
  imageUrl String? // optional question image (picture-based questions)
  required Boolean          @default(true)
  points   Int              @default(0)
  exam     Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  choices  ExamChoice[]

  @@index([examId])
  @@map("exam_questions")
}

/// ExamChoice — a selectable option for a SINGLE/MULTIPLE question.
model ExamChoice {
  id         String       @id @default(cuid())
  questionId String
  order      Int
  label      String
  imageUrl   String? // optional option image (picture-based questions)
  isCorrect  Boolean      @default(false)
  question   ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("exam_choices")
}

/// ExamAudience — who an exam targets (drives the live recipient preview).
model ExamAudience {
  id           String           @id @default(cuid())
  examId       String           @unique
  mode         ExamAudienceMode
  branchId     String? // scalar ref → branches.id
  departmentId String? // scalar ref → departments.id
  role         String? // scalar role filter (e.g. BRANCH_MANAGER)
  randomCount  Int?
  customRules  Json?
  recipients   Int              @default(0) // cached computed count
  exam         Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_audiences")
}

/// ExamInvite — an employee invited to take an exam.
model ExamInvite {
  id         String           @id @default(cuid())
  examId     String
  employeeId String // scalar ref → users.id
  status     ExamInviteStatus @default(INVITED)
  invitedAt  DateTime         @default(now())
  exam       Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, employeeId])
  @@index([examId, status])
  @@map("exam_invites")
}

/// ExamResponse — an employee's submission for an exam.
model ExamResponse {
  id           String       @id @default(cuid())
  examId       String
  employeeId   String // scalar ref → users.id
  startedAt    DateTime     @default(now())
  submittedAt  DateTime?
  marks        Float? // 0–100
  rank         Int?
  timeTakenSec Int?
  exam         Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers      ExamAnswer[]

  @@unique([examId, employeeId])
  @@index([examId])
  @@map("exam_responses")
}

/// ExamAnswer — an employee's answer to one question.
model ExamAnswer {
  id          String       @id @default(cuid())
  responseId  String
  questionId  String // scalar ref → exam_questions.id
  choiceIds   String[] // selected ExamChoice ids
  textValue   String?
  ratingValue Int?
  response    ExamResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@map("exam_answers")
}

/// AudienceTemplate — a saved, reusable audience definition (filters +/or an
/// explicit employee set) that an admin can apply to any exam. Phase A.
model AudienceTemplate {
  id          String                @id @default(cuid())
  name        String
  createdById String // scalar ref → users.id (no relation)
  mode        ExamParticipationMode @default(CUSTOM)
  filters     Json? // { include: {...}, exclude: {...}, search } snapshot
  employeeIds String[] // resolved / hand-picked employee ids
  count       Int                   @default(0) // cached recipient count
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([createdById])
  @@map("audience_templates")
}

enum ExamParticipationMode {
  INTERNAL
  INTERNAL_EXTERNAL
  OPEN
  CUSTOM
}

enum ExamApprovalMode {
  AUTO
  MANUAL
}

enum RegistrantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
}

enum ExamQuestionType {
  SINGLE
  MULTIPLE
  SHORT
  LONG
  RATING
  TRUE_FALSE
  LIKERT
  RANKING
  POLL
  WORD_CLOUD
  PICTURE
}

enum ExamAudienceMode {
  ALL
  BRANCH
  DEPT
  BM
  RM
  RANDOM
  CUSTOM
}

enum ExamInviteStatus {
  INVITED
  STARTED
  COMPLETED
}
